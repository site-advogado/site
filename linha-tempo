<!DOCTYPE html>
<html lang="pt-br" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minha Linha do Tempo | Gestão Jurídica</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: { pearl: '#FDFCF8', softBlack: '#1A1A1A', satinGold: '#C5A059', darkGold: '#A37E3B' },
                    fontFamily: { serif: ['Cinzel', 'serif'], sans: ['Montserrat', 'sans-serif'] }
                }
            }
        }
        if (localStorage.getItem('ADV_GLOBAL_THEME') === 'dark') {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.add('light');
        }
    </script>
    <style>
        body { -webkit-user-select: none; user-select: none; scroll-behavior: smooth; }
        .gold-gradient { background: linear-gradient(135deg, #C5A059 0%, #A37E3B 100%); }
        #process-carousel {
            display: flex; overflow-x: auto; scroll-snap-type: x mandatory;
            gap: 16px; padding: 10px 0; scrollbar-width: none;
            justify-content: flex-start; cursor: grab;
        }
        #process-carousel:active { cursor: grabbing; }
        #process-carousel::-webkit-scrollbar { display: none; }
        .process-card {
            flex: 0 0 85%; scroll-snap-align: center;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 2px solid transparent; pointer-events: auto !important;
        }
        .process-card.active {
            border-color: #C5A059; transform: scale(1.02);
            box-shadow: 0 20px 25px -5px rgba(197,160,89,0.15);
        }
        .timeline-item { animation: fadeInUp 0.5s ease forwards; opacity: 0; }
        @keyframes fadeInUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
        .loader { border: 3px solid #f3f3f3; border-top: 3px solid #C5A059; border-radius: 50%; width: 30px; height: 30px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform:rotate(0deg); } 100% { transform:rotate(360deg); } }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-thumb { background: #C5A059; border-radius: 10px; }
        .dot { width:8px; height:8px; border-radius:50%; background-color:#C5A059; opacity:0.3; transition:opacity 0.3s; }
        .dot.active { opacity:1; transform:scale(1.2); }
    </style>
</head>
<body class="bg-pearl dark:bg-softBlack text-softBlack dark:text-pearl min-h-screen font-sans transition-colors duration-300">

    <div id="globalLoader" class="fixed inset-0 z-[200] flex items-center justify-center bg-pearl/60 dark:bg-softBlack/60 backdrop-blur-md">
        <div class="bg-white dark:bg-zinc-900 p-8 rounded-[2.5rem] shadow-2xl flex flex-col items-center border border-satinGold/20">
            <div class="loader mb-4"></div>
            <p class="text-satinGold font-bold text-[10px] tracking-[0.3em] uppercase">Sincronizando dados</p>
        </div>
    </div>

    <header class="fixed top-0 w-full z-50 p-4 bg-pearl/70 dark:bg-softBlack/70 backdrop-blur-lg border-b border-satinGold/10">
        <div class="max-w-lg mx-auto flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 gold-gradient rounded-full flex items-center justify-center text-white shadow-lg">
                    <i class="fas fa-shield-halved text-sm"></i>
                </div>
                <h1 class="font-serif font-bold text-darkGold tracking-widest text-xs uppercase">Área Segura</h1>
            </div>
            <div class="flex gap-3 items-center">
                <button onclick="toggleDarkMode()" class="w-10 h-10 flex items-center justify-center rounded-full bg-white dark:bg-zinc-900 border border-satinGold/20 shadow-sm transition-all active:scale-90">
                    <i id="themeIcon" class="fas fa-moon text-satinGold"></i>
                </button>
                <button onclick="logout()" class="bg-red-500/10 text-red-500 px-5 py-2 rounded-full text-[10px] font-bold uppercase tracking-widest hover:bg-red-500 hover:text-white transition-all">Sair</button>
            </div>
        </div>
    </header>

    <main class="pt-24 pb-20 px-4 max-w-lg mx-auto">
        <section class="mb-6 animate-pulse text-center">
            <p class="text-[10px] font-bold text-satinGold uppercase tracking-[0.3em] mb-1">Bem-vindo(a)</p>
            <h2 id="client-name-display" class="font-serif text-xl font-bold text-darkGold uppercase">Carregando...</h2>
        </section>
        <section class="mb-8 mt-4 text-center">
            <h2 class="font-serif text-3xl font-bold text-darkGold uppercase tracking-tighter">Linha do Tempo</h2>
            <div class="w-12 h-1 gold-gradient mx-auto mt-2 rounded-full opacity-50"></div>
        </section>

        <div id="process-carousel" class="mb-2"></div>
        <div id="carousel-dots" class="flex justify-center gap-2 mb-6"></div>

        <div class="grid grid-cols-2 gap-4 mb-10">
            <div class="col-span-2 bg-white dark:bg-zinc-900 p-6 rounded-[2rem] border border-satinGold/10 shadow-sm">
                <div class="flex items-center justify-between mb-2">
                    <p class="text-[9px] font-bold text-satinGold uppercase tracking-[0.2em]">Status do Processo</p>
                    <span class="flex h-2 w-2 rounded-full bg-satinGold animate-ping"></span>
                </div>
                <h3 id="current-status-text" class="font-serif text-lg text-darkGold font-bold uppercase leading-tight">Carregando...</h3>
            </div>
            <div class="bg-white dark:bg-zinc-900 p-5 rounded-[2rem] border border-satinGold/10 shadow-sm">
                <p class="text-[9px] font-bold text-satinGold uppercase tracking-widest mb-3 text-center">Progresso</p>
                <div class="relative h-16 w-16 mx-auto flex items-center justify-center">
                    <svg class="w-full h-full transform -rotate-90">
                        <circle cx="32" cy="32" r="28" stroke="currentColor" stroke-width="4" fill="transparent" class="text-gray-100 dark:text-zinc-800"/>
                        <circle id="progress-circle" cx="32" cy="32" r="28" stroke="url(#goldGradient)" stroke-width="4" fill="transparent" stroke-dasharray="175.9" stroke-dashoffset="175.9" class="transition-all duration-1000 ease-out"/>
                        <defs>
                            <linearGradient id="goldGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                                <stop offset="0%" stop-color="#C5A059"/>
                                <stop offset="100%" stop-color="#A37E3B"/>
                            </linearGradient>
                        </defs>
                    </svg>
                    <span id="progress-percentage" class="absolute font-bold text-[11px]">0%</span>
                </div>
            </div>
            <div class="bg-white dark:bg-zinc-900 p-5 rounded-[2rem] border border-satinGold/10 shadow-sm flex flex-col justify-center items-center">
                <p class="text-[9px] font-bold text-satinGold uppercase tracking-widest mb-1">Eventos</p>
                <span id="event-count" class="font-serif text-3xl font-bold text-darkGold">0</span>
                <p class="text-[8px] opacity-50 uppercase font-bold mt-1">Registrados</p>
            </div>
        </div>

        <div id="timeline-container" class="relative border-l-2 border-satinGold/20 ml-3 pl-8 space-y-8"></div>
    </main>

    <script>
        const WEB_APP_URL = "https://api-advogada.siterefrigeracaoeliezer.workers.dev/api/v1";
        const MASTER_API_KEY = "Adv_Seguro_2026_##";
        let globalData = [];
        let isLooping = false;
        let scrollLocked = false;

        function toStr(val) { return String(val); }

        function formatDateOnly(isoString) {
            if (!isoString) return "";
            if (isoString.includes('/')) return isoString;
            try {
                const date = new Date(isoString);
                const day = String(date.getDate()).padStart(2, '0');
                const month = String(date.getMonth() + 1).padStart(2, '0');
                const year = date.getFullYear();
                return `${day}/${month}/${year}`;
            } catch (e) {
                return isoString;
            }
        }

        function logout() {
            localStorage.removeItem('ADV_USER_EMAIL');
            localStorage.removeItem('ADV_USER_TOKEN');
            window.location.href = "index.html";
        }

        async function init() {
            const email = localStorage.getItem('ADV_USER_EMAIL');
            try {
                const res = await fetch(WEB_APP_URL, {
                    method: 'POST',
                    body: JSON.stringify({ api_key: MASTER_API_KEY, action: 'timeline', email: email })
                });
                const data = await res.json();
                globalData = data;
                if (globalData.length > 0) {
                    renderCarousel();
                } else {
                    document.getElementById('client-name-display').innerText = "Nenhum processo encontrado";
                    document.getElementById('current-status-text').innerText = "Sem dados";
                }
            } catch (error) {
                console.error("Erro ao buscar dados:", error);
                globalData = [
                    {
                        id: "001",
                        cliente: "Teste de Nome Longo para Visualização do Cliente",
                        numero_processo: "1234567-89.2026.8.00.0001",
                        tipo_acao: "Direito Civil",
                        obs: "Audiência marcada para o dia 15/05 às 14h.",
                        atualizacoes: [
                            { data: "2026-04-22T22:20:46.256Z", status: "Petição inicial protocolada", descricao: "Descrição de teste." },
                            { data: "2026-04-23T10:00:00.000Z", status: "Despacho do juiz", descricao: "Outra descrição de teste." }
                        ]
                    }
                ];
                renderCarousel();
            } finally {
                setTimeout(() => { document.getElementById('globalLoader').style.display = 'none'; }, 800);
            }
        }

        function renderCarousel() {
            const carousel = document.getElementById('process-carousel');
            const dotsContainer = document.getElementById('carousel-dots');

            let displayData = [...globalData];
            if (globalData.length > 1) {
                displayData = [...globalData, ...globalData, ...globalData];
                isLooping = true;
                carousel.style.justifyContent = "flex-start";
            } else {
                isLooping = false;
                carousel.style.justifyContent = "center";
            }

            carousel.innerHTML = displayData.map((proc, index) => `
                <div class="process-card bg-white dark:bg-zinc-900 p-6 rounded-[2.5rem] shadow-md cursor-pointer"
                     data-id="${toStr(proc.id)}" id="card-idx-${index}">
                    <p class="text-[9px] font-bold text-satinGold uppercase tracking-widest">${proc.tipo_acao}</p>
                    <h4 class="font-serif font-bold text-darkGold text-sm mt-1 truncate">${proc.numero_processo}</h4>
                    <div class="flex items-center gap-2 mt-4">
                        <i class="fas fa-info-circle text-[10px] text-satinGold opacity-50"></i>
                        <span class="text-[9px] font-bold opacity-40 uppercase">${proc.obs || "Sem observações adicionais"}</span>
                    </div>
                </div>
            `).join('');

            document.querySelectorAll('.process-card').forEach(card => {
                let touchMoved = false;
                card.addEventListener('touchstart', () => { touchMoved = false; }, { passive: true });
                card.addEventListener('touchmove', () => { touchMoved = true; }, { passive: true });
                card.addEventListener('touchend', (e) => {
                    if (!touchMoved) {
                        e.preventDefault();
                        selectProcess(card.getAttribute('data-id'));
                    }
                });
                card.addEventListener('click', () => {
                    selectProcess(card.getAttribute('data-id'));
                });
            });

            dotsContainer.innerHTML = globalData.map((_, i) => `<div class="dot" id="dot-${i}"></div>`).join('');

            if (isLooping) {
                scrollLocked = true;
                const cardWidth = carousel.offsetWidth * 0.85 + 16;
                carousel.scrollLeft = globalData.length * cardWidth;
                setTimeout(() => {
                    scrollLocked = false;
                    selectProcess(toStr(globalData[0].id));
                }, 150);
            } else {
                setTimeout(() => { selectProcess(toStr(globalData[0].id)); }, 50);
            }

            setupDraggableCarousel(carousel);
            setupCarouselScroll(carousel);
        }

        function setupCarouselScroll(carousel) {
            let scrollTimer = null;
            carousel.addEventListener('scroll', () => {
                if (scrollLocked) return;
                if (isLooping) {
                    const cardWidth = document.querySelector('.process-card').offsetWidth + 16;
                    const totalWidth = globalData.length * cardWidth;
                    if (carousel.scrollLeft <= 0) {
                        carousel.scrollLeft = totalWidth;
                    } else if (carousel.scrollLeft >= carousel.scrollWidth - carousel.offsetWidth) {
                        carousel.scrollLeft = carousel.scrollWidth - carousel.offsetWidth - totalWidth;
                    }
                }
                clearTimeout(scrollTimer);
                scrollTimer = setTimeout(() => {
                    if (scrollLocked) return;
                    let closestCard = null;
                    let closestOffset = Infinity;
                    document.querySelectorAll('.process-card').forEach(card => {
                        const rect = card.getBoundingClientRect();
                        const offset = Math.abs(rect.left + rect.width / 2 - window.innerWidth / 2);
                        if (offset < closestOffset) { closestOffset = offset; closestCard = card; }
                    });
                    if (closestCard) selectProcess(closestCard.getAttribute('data-id'));
                }, 80);
            });
        }

        function setupDraggableCarousel(slider) {
            let isDown = false, startX, scrollLeft;
            slider.addEventListener('mousedown', (e) => {
                isDown = true;
                startX = e.pageX - slider.offsetLeft;
                scrollLeft = slider.scrollLeft;
            });
            slider.addEventListener('mouseleave', () => { isDown = false; });
            slider.addEventListener('mouseup', () => { isDown = false; });
            slider.addEventListener('mousemove', (e) => {
                if (!isDown) return;
                const walk = e.pageX - slider.offsetLeft - startX;
                if (Math.abs(walk) > 5) { e.preventDefault(); slider.scrollLeft = scrollLeft - walk; }
            });
        }

        function selectProcess(id) {
            const idStr = toStr(id);
            const proc = globalData.find(p => toStr(p.id) === idStr);

            if (!proc) return;

            document.getElementById('client-name-display').innerText = proc.cliente || "Usuário";

            document.querySelectorAll('.process-card').forEach(card => {
                card.classList.toggle('active', card.getAttribute('data-id') === idStr);
            });

            const actualIndex = globalData.findIndex(p => toStr(p.id) === idStr);
            document.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === actualIndex));

            const lastEvent = proc.atualizacoes[proc.atualizacoes.length - 1] || { status: "Nenhum" };
            document.getElementById('current-status-text').innerText = lastEvent.status;
            document.getElementById('event-count').innerText = proc.atualizacoes.length;

            const progressValue = Math.min(proc.atualizacoes.length * 20, 100);
            const offset = (2 * Math.PI * 28) * (1 - progressValue / 100);
            document.getElementById('progress-circle').style.strokeDashoffset = offset;
            document.getElementById('progress-percentage').innerText = progressValue + '%';

            document.getElementById('timeline-container').innerHTML = [...proc.atualizacoes].reverse().map((ev, i) => `
                <div class="timeline-item relative bg-white dark:bg-zinc-900 p-6 rounded-[2rem] border border-satinGold/10 shadow-sm" style="animation-delay:${i * 0.1}s">
                    <div class="absolute -left-[41px] top-1/2 -translate-y-1/2 w-4 h-4 rounded-full gold-gradient border-4 border-pearl dark:border-softBlack shadow-sm"></div>
                    <p class="text-[9px] font-bold text-satinGold uppercase mb-1 tracking-widest">${formatDateOnly(ev.data)}</p>
                    <h5 class="font-serif font-bold text-darkGold text-base mb-2 uppercase">${ev.status}</h5>
                    <p class="text-xs opacity-70 leading-relaxed font-medium">${ev.descricao || "Sem descrição."}</p>
                </div>
            `).join('');
        }

        function toggleDarkMode() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('ADV_GLOBAL_THEME', isDark ? 'dark' : 'light');
            document.getElementById('themeIcon').classList.replace(isDark ? 'fa-moon' : 'fa-sun', isDark ? 'fa-sun' : 'fa-moon');
        }

        document.addEventListener('contextmenu', e => e.preventDefault());
        document.addEventListener('keydown', e => {
            if (e.key === "F12" || (e.ctrlKey && e.shiftKey && ["I","J","C"].includes(e.key))) e.preventDefault();
        });

        window.onload = init;
    </script>
</body>
</html>
