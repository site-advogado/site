const MODAL_ADMIN_TEMPLATE = `
<div id="modalAdmin" class="fixed inset-0 z-[120] hidden flex items-center justify-center p-4 modal-blur bg-black/60">
    <div class="bg-pearl dark:bg-zinc-900 w-full max-w-sm rounded-[30px] p-10 border border-satinGold shadow-2xl text-center">
            <h3 class="font-serif text-2xl mb-6 text-darkGold uppercase tracking-widest font-bold">Acesso Restrito</h3>
                    <div class="space-y-6 text-left">
                                <div>
                                                <label class="text-[10px] uppercase font-bold text-satinGold tracking-widest">Usuário Master</label>
                                                                <input type="text" id="adminUser" class="w-full bg-transparent border-b border-satinGold/50 py-2 outline-none focus:border-satinGold dark:text-white transition-all">
                                                                            </div>
                                                                                        <div>
                                                                                                        <label class="text-[10px] uppercase font-bold text-satinGold tracking-widest">Senha de Acesso</label>
                                                                                                                        <input type="password" id="adminPass" class="w-full bg-transparent border-b border-satinGold/50 py-2 outline-none focus:border-satinGold dark:text-white transition-all">
                                                                                                                                    </div>
                                                                                                                                                <button onclick="realizarLoginAdmin()" id="btnAdminLogin" class="w-full gold-gradient text-white font-bold py-4 rounded-xl shadow-lg text-xs tracking-widest uppercase hover:scale-[1.02] transition-transform mt-4">Entrar no Sistema</button>
                                                                                                                                                            <button onclick="closeAdminModal()" class="w-full text-[10px] opacity-50 uppercase font-bold tracking-widest">Cancelar</button>
                                                                                                                                                                    </div>
                                                                                                                                                                        </div>
                                                                                                                                                                        </div>`;

                                                                                                                                                                        export default {
                                                                                                                                                                          async fetch(request, env) {
                                                                                                                                                                              const url = new URL(request.url);
                                                                                                                                                                                  const origin = request.headers.get("Origin");

                                                                                                                                                                                      const allowedOrigins = [
                                                                                                                                                                                            "https://site-advogado.github.io",
                                                                                                                                                                                                  "https://texte123445.blogspot.com"
                                                                                                                                                                                                      ];

                                                                                                                                                                                                          const isAllowed = allowedOrigins.includes(origin);

                                                                                                                                                                                                              if (!isAllowed && request.method !== "OPTIONS") {
                                                                                                                                                                                                                    return new Response(JSON.stringify({ status: "erro", message: "Origem não autorizada." }), {
                                                                                                                                                                                                                            status: 403,
                                                                                                                                                                                                                                    headers: { "Content-Type": "application/json" }
                                                                                                                                                                                                                                          });
                                                                                                                                                                                                                                              }

                                                                                                                                                                                                                                                  const corsHeaders = {
                                                                                                                                                                                                                                                        "Access-Control-Allow-Origin": origin, 
                                                                                                                                                                                                                                                              "Access-Control-Allow-Methods": "POST, OPTIONS",
                                                                                                                                                                                                                                                                    "Access-Control-Allow-Headers": "Content-Type",
                                                                                                                                                                                                                                                                          "Access-Control-Allow-Credentials": "true",
                                                                                                                                                                                                                                                                              };

                                                                                                                                                                                                                                                                                  if (request.method === "OPTIONS") return new Response(null, { headers: corsHeaders });

                                                                                                                                                                                                                                                                                      if (url.pathname === "/api/v1") {
                                                                                                                                                                                                                                                                                            try {
                                                                                                                                                                                                                                                                                                    const body = await request.json();
                                                                                                                                                                                                                                                                                                            const cookieHeader = request.headers.get("Cookie") || "";
                                                                                                                                                                                                                                                                                                                    const sessionToken = cookieHeader.split('; ').find(row => row.trim().startsWith('ADV_SESSION_TOKEN='))?.split('=')[1];

                                                                                                                                                                                                                                                                                                                            // --- PROTEÇÃO DE NÍVEL BANCÁRIO (INJEÇÃO LADO SERVIDOR) ---
                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                            // 1. Injeta a Chave Mestra que está protegida no Cloudflare
                                                                                                                                                                                                                                                                                                                                                    body.api_key = env.MASTER_API_KEY; 

                                                                                                                                                                                                                                                                                                                                                            // 2. Injeta o Token de Sessão se existir
                                                                                                                                                                                                                                                                                                                                                                    if (sessionToken) body.token = sessionToken;
                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                    // 3. Injeta o IP Real detectado pela Cloudflare (Mais seguro que ipify)
                                                                                                                                                                                                                                                                                                                                                                                            body.ip = request.headers.get("cf-connecting-ip") || "0.0.0.0"; 

                                                                                                                                                                                                                                                                                                                                                                                                    // ---------------------------------------------------------

                                                                                                                                                                                                                                                                                                                                                                                                            const googleResponse = await fetch(env.GOOGLE_SCRIPT_URL, {
                                                                                                                                                                                                                                                                                                                                                                                                                      method: "POST",
                                                                                                                                                                                                                                                                                                                                                                                                                                body: JSON.stringify(body),
                                                                                                                                                                                                                                                                                                                                                                                                                                          headers: { "Content-Type": "application/json" }
                                                                                                                                                                                                                                                                                                                                                                                                                                                  });

                                                                                                                                                                                                                                                                                                                                                                                                                                                          const data = await googleResponse.json();
                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                                                                                                                          if (data.status === "abrir_modal_admin") {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      data.html = MODAL_ADMIN_TEMPLATE;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      const responseHeaders = new Headers(corsHeaders);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              responseHeaders.set("Content-Type", "application/json");

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      if (data.token) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                responseHeaders.append("Set-Cookie", `ADV_SESSION_TOKEN=${data.token}; HttpOnly; Secure; SameSite=None; Path=/; Max-Age=3600`);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          delete data.token; 
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          return new Response(JSON.stringify(data), { headers: responseHeaders });

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                } catch (err) {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        return new Response(JSON.stringify({ status: "erro", message: "Erro de conexão Worker." }), { headers: corsHeaders });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      return new Response("Not Found", { status: 404 });
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        };
